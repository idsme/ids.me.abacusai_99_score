---
import type { CollectionEntry } from "astro:content";
import { getPath } from "@/utils/getPath";
import { calculateReadingTime } from "@/utils/readingTime";
import { slugifyStr } from "@/utils/slugify";
import Datetime from "./Datetime.astro";

export interface Props extends CollectionEntry<"blog"> {
  variant?: "h2" | "h3";
  showImage?: boolean;
}

const { variant = "h2", data, id, filePath, body, showImage = true } = Astro.props;

const { title, description, pubDatetime, modDatetime, timezone, heroImage, tags } = data;
const readingTime = calculateReadingTime(body ?? "");

const headerProps = {
  style: { viewTransitionName: slugifyStr(title) },
  class: "text-lg font-medium decoration-dashed hover:underline",
};
---

<li class="my-8">
  <div>
    <a
      href={getPath(id, filePath)}
      class="inline-block text-lg font-medium text-accent decoration-dashed underline-offset-4 focus-visible:no-underline focus-visible:underline-offset-0"
    >
      {
        variant === "h2" ? (
          <h2 {...headerProps}>{title}</h2>
        ) : (
          <h3 {...headerProps}>{title}</h3>
        )
      }
    </a>
    {tags.length > 0 && (
      <div class="mb-1 flex flex-wrap gap-2">
        {tags.map((tag: string) => (
          <a
            href={`/tags/${slugifyStr(tag)}`}
            class="text-xs opacity-70 hover:opacity-100 hover:text-accent decoration-dashed underline-offset-4 underline"
          >
            #{tag}
          </a>
        ))}
      </div>
    )}
    <div class="flex items-center gap-3 mb-3">
      <Datetime {pubDatetime} {modDatetime} {timezone} />
      <span class="text-sm italic opacity-80">• {readingTime}</span>
    </div>
    <div class="flex gap-4 items-start">
      {showImage && heroImage && (
        <a
          href={getPath(id, filePath)}
          class="flex-shrink-0 hidden sm:block group"
        >
          <img
            src={heroImage}
            alt={title}
            width={140}
            height={79}
            class="rounded shadow-sm transition-all duration-200 group-hover:shadow-md group-hover:scale-105 object-cover"
            loading="lazy"
          />
        </a>
      )}
      <p class="opacity-80 flex-1">{description}</p>
    </div>
  </div>
</li>
